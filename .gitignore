# =====================================================================
# CriterIA — gitignore raíz del monorepo
# =====================================================================

# --- Dependencias / artefactos de build ---
node_modules
dist
dist-ssr
dev-dist
build
*.local
*.tsbuildinfo

# Artefactos huérfanos que vite-plugin-pwa puede dejar fuera de dist/
workbox-*.js
sw.js
registerSW.js

# Yarn 4 (berry): rastreamos solo lo mínimo (releases, plugins, patches).
**/.yarn/cache
**/.yarn/install-state.gz
**/.yarn/unplugged
**/.yarn/build-state.yml
.pnp.*

# Prisma: salida del client cuando algún `prisma generate` viejo dejó residuo.
nelai-pwa/generated/

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Editor / OS ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Cursor / agente ---
.cursor/

# --- Variables y secretos ---
.env
.env.local
.env.*.local
!.env.example

# Lockfiles de gestores que no usamos (proyecto = Yarn 4 berry).
package-lock.json
pnpm-lock.yaml

# --- Certificados locales (HTTPS dev) ---
.certs
**/.certs

# --- Etherpad: APIKEY y datos locales del contenedor ---
nelai-pwa/etherpad/APIKEY.txt
nelai-pwa/etherpad/var/

# --- Misc ---
*.pid
*.seed
*.pid.lock
coverage/
.nyc_output/
